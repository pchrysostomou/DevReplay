# ─────────────────────────────────────────────
# DevReplay — Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit .env to git
# ─────────────────────────────────────────────

# GitHub App — get these from github.com/settings/apps/<your-app>
GITHUB_APP_ID=              # e.g. 123456
GITHUB_WEBHOOK_SECRET=      # random string you chose when creating the App

# GitHub App Private Key
# Paste the full PEM content — replace actual newlines with \n
# Example: "-----BEGIN RSA PRIVATE KEY-----\nMIIEo...\n-----END RSA PRIVATE KEY-----"
GITHUB_PRIVATE_KEY=

# Groq API — get from console.groq.com
# Needed for W2 (AI review engine) — fill in now for convenience
GROQ_API_KEY=gsk_your_groq_api_key_here

# Server
PORT=3000
NODE_ENV=development
